{
  "name": "@quill/agent",
  "version": "0.1.0",
  "description": "Shared Agent SDK for QuillSocial with OpenAI integration and usage logging",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@prisma/client": ">=4.16.0",
    "openai": "^4",
    "zod": "^3"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "@vitest/coverage-v8": "^1.0.4",
    "eslint": "^9.39.4",
    "tsup": "^8.0.1",
    "typescript": "^5.9.3",
    "vitest": "^1.0.4"
  },
  "keywords": [
    "agent",
    "openai",
    "ai",
    "sdk",
    "tools"
  ],
  "author": "QuillSocial",
  "license": "MIT"
}
